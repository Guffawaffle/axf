{
  "manifestVersion": "axf/v0",
  "family": "lex",
  "scope": "global",
  "provider": "lex",
  "adapterType": "cli",
  "providerArgStyle": "double-dash-kebab",
  "outputModes": ["json"],
  "sideEffects": "read",
  "lifecycleState": "active",
  "owner": "module:lex",
  "commands": {
    "status": {
      "summary": "Compact Lex state and health summary",
      "executionTarget": {
        "command": "lex",
        "args": ["introspect", "--json", "--format", "compact"]
      },
      "args": {},
      "sideEffects": "read"
    },
    "introspect": {
      "summary": "Full Lex introspection output",
      "executionTarget": {
        "command": "lex",
        "args": ["introspect", "--json"]
      },
      "args": {
        "format": { "type": "string", "description": "full or compact" }
      },
      "sideEffects": "read"
    },
    "recall": {
      "summary": "Recall frames by query or list recent frames",
      "executionTarget": {
        "command": "lex",
        "args": ["recall", "--json"]
      },
      "args": {
        "query": { "type": "string", "description": "Search query or reference point" },
        "list": { "type": "integer", "description": "List recent frames" },
        "exact": { "type": "boolean" },
        "mode": { "type": "string" },
        "fold-radius": { "type": "integer" },
        "auto-radius": { "type": "boolean" },
        "max-tokens": { "type": "integer" },
        "summary": { "type": "boolean" },
        "strict": { "type": "boolean" },
        "format": { "type": "string" }
      },
      "sideEffects": "read"
    },
    "search": {
      "summary": "Search Lex frames by query",
      "executionTarget": {
        "command": "lex",
        "args": ["recall", "--json"]
      },
      "args": {
        "query": { "type": "string", "required": true, "description": "Search query" },
        "exact": { "type": "boolean" },
        "mode": { "type": "string" },
        "fold-radius": { "type": "integer" },
        "auto-radius": { "type": "boolean" },
        "max-tokens": { "type": "integer" },
        "summary": { "type": "boolean" },
        "strict": { "type": "boolean" },
        "format": { "type": "string" }
      },
      "sideEffects": "read"
    },
    "policy-check": {
      "summary": "Validate Lex policy files and optional module mapping",
      "executionTarget": {
        "command": "lex",
        "args": ["policy", "check", "--json"]
      },
      "args": {
        "match": { "type": "boolean" },
        "policy": { "type": "string" },
        "src-dir": { "type": "string" }
      },
      "sideEffects": "read"
    },
    "remember": {
      "summary": "Capture a work-session frame in Lex",
      "executionTarget": {
        "command": "lex",
        "args": ["remember", "--json"]
      },
      "args": {
        "jira": { "type": "string" },
        "reference-point": { "type": "string" },
        "summary": { "type": "string", "required": true },
        "next": { "type": "string" },
        "modules": { "type": "string", "required": true },
        "blockers": { "type": "string" },
        "merge-blockers": { "type": "string" },
        "tests-failing": { "type": "string" },
        "keywords": { "type": "string" },
        "feature-flags": { "type": "string" },
        "permissions": { "type": "string" },
        "strict": { "type": "boolean" },
        "no-substring": { "type": "boolean" },
        "skip-policy": { "type": "boolean" },
        "dry-run": { "type": "boolean" }
      },
      "sideEffects": "write"
    },
    "log-frame": {
      "summary": "Alias of lex remember for frame logging",
      "executionTarget": {
        "command": "lex",
        "args": ["remember", "--json"]
      },
      "args": {
        "jira": { "type": "string" },
        "reference-point": { "type": "string" },
        "summary": { "type": "string", "required": true },
        "next": { "type": "string" },
        "modules": { "type": "string", "required": true },
        "blockers": { "type": "string" },
        "merge-blockers": { "type": "string" },
        "tests-failing": { "type": "string" },
        "keywords": { "type": "string" },
        "feature-flags": { "type": "string" },
        "permissions": { "type": "string" },
        "strict": { "type": "boolean" },
        "no-substring": { "type": "boolean" },
        "skip-policy": { "type": "boolean" },
        "dry-run": { "type": "boolean" }
      },
      "sideEffects": "write"
    },
    "note": {
      "summary": "Alias of lex remember for repo notes",
      "executionTarget": {
        "command": "lex",
        "args": ["remember", "--json"]
      },
      "args": {
        "jira": { "type": "string" },
        "reference-point": { "type": "string" },
        "summary": { "type": "string", "required": true },
        "next": { "type": "string" },
        "modules": { "type": "string", "required": true },
        "blockers": { "type": "string" },
        "merge-blockers": { "type": "string" },
        "tests-failing": { "type": "string" },
        "keywords": { "type": "string" },
        "feature-flags": { "type": "string" },
        "permissions": { "type": "string" },
        "strict": { "type": "boolean" },
        "no-substring": { "type": "boolean" },
        "skip-policy": { "type": "boolean" },
        "dry-run": { "type": "boolean" }
      },
      "sideEffects": "write"
    }
  }
}