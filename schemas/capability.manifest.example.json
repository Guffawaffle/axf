{
  "manifestVersion": "axf/v0",
  "id": "global.echo.say",
  "summary": "Return a message through the built-in echo provider",
  "provider": "echo",
  "adapterType": "internal",
  "executionTarget": {
    "handler": "echo.say"
  },
  "argsSchema": {
    "type": "object",
    "properties": {
      "message": { "type": "string" }
    },
    "required": ["message"],
    "additionalProperties": false
  },
  "outputModes": ["json", "text"],
  "sideEffects": "none",
  "scope": "global",
  "lifecycleState": "active",
  "defaults": {},
  "policies": [],
  "owner": "module:echo",
  "recommendedFor": ["session-start"],
  "examples": [
    "axf run echo say --message hello"
  ]
}
