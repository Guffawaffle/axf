{
  "name": "@smartergpt/axf",
  "version": "0.1.4",
  "private": false,
  "type": "module",
  "description": "Manifest-driven AXF capability router with CLI and MCP entrypoints.",
  "bin": {
    "axf": "./bin/axf.js",
    "axf-mcp": "./bin/axf-mcp.js"
  },
  "files": [
    "bin/",
    "src/",
    "adapters/",
    "manifests/",
    "schemas/",
    "axf.workspace.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "axf": "node bin/axf.js",
    "axf-mcp": "node bin/axf-mcp.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks",
    "test": "node --test"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Guffawaffle/ax-framework.git"
  },
  "homepage": "https://smartergpt.dev/axf",
  "bugs": {
    "url": "https://github.com/Guffawaffle/ax-framework/issues"
  },
  "mcpName": "dev.smartergpt/axf",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "simple-git-hooks": "^2.13.1"
  }
}
